# BFlow Backend - Development Local Environment Variables
# Copy this to .env and fill with your actual values

# Server Configuration
PORT=8080
BASE_URL=http://localhost:8080

# PostgreSQL Database Configuration (Local Development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bflow_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_DRIVER=org.postgresql.Driver
DB_SSL_MODE=disable

# Redis Configuration (Local Development)
REDIS_HOST=localhost
REDIS_PORT=6379

# Google OAuth2 Configuration
# Get these credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

AWS_REGION=
AWS_SES_FROM_EMAIL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

#Image from
LOGO_URL=
FRONTEND_URL=https://www.bflow-studio.com

# Application Profiles  
# Options: default (PostgreSQL), h2 (in-memory for quick testing)
# SPRING_PROFILES_ACTIVE=default